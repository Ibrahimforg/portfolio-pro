{
  "name": "portfolio-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 --turbo",
    "dev-webpack": "next dev -p 3001 --webpack",
    "dev:turbo": "next dev -p 3001 --turbo",
    "dev:fast": "NODE_ENV=development next dev -p 3001 --turbo",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ./cleanup.ps1 && npm run dev:fast",
    "build": "next build",
    "build:clean": "powershell -ExecutionPolicy Bypass -File ./cleanup.ps1 && npm run build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint && npm run type-check && npm run test:ci",
    "cleanup": "powershell -ExecutionPolicy Bypass -File ./cleanup.ps1",
    "kill": "taskkill /F /IM node.exe"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
